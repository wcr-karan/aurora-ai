# ─────────────────────────────────────────────────────────────────────────────
# Helpdesk AI — environment configuration
# Copy this file to `.env` and fill in values. The platform runs fully offline
# in DEMO mode with NO keys set — every variable below is optional.
# ─────────────────────────────────────────────────────────────────────────────

# Database ────────────────────────────────────────────────────────────────────
# Local dev uses a zero-config SQLite file. For production, point this at a
# managed Postgres (Neon / Supabase / RDS) and set DATABASE_PROVIDER=postgresql
# in prisma/schema.prisma. The data model is provider-portable.
DATABASE_URL="file:./dev.db"

# Auth ────────────────────────────────────────────────────────────────────────
# 32+ char secret used to sign session JWTs. A dev fallback is used if unset,
# but ALWAYS set a strong random value in production.
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# AI provider ─────────────────────────────────────────────────────────────────
# When ANTHROPIC_API_KEY is set, answers are generated by Claude (recommended).
# When unset, a fully-offline grounded mock model answers from retrieved chunks
# so the platform is demonstrable without any external dependency or cost.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# Embeddings ──────────────────────────────────────────────────────────────────
# When OPENAI_API_KEY is set, documents are embedded with text-embedding-3-small.
# When unset, a deterministic local embedder is used (no network) so retrieval
# works offline. Real embeddings are recommended for production semantic quality.
OPENAI_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"

# App ─────────────────────────────────────────────────────────────────────────
# Public origin, used to build the embeddable widget snippet shown to admins.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
