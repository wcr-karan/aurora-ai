# ─────────────────────────────────────────────────────────────────────────────
# Helpdesk AI — environment configuration
# Copy this file to `.env` and fill in values. The platform runs fully offline
# in DEMO mode with NO keys set — every variable below is optional.
# ─────────────────────────────────────────────────────────────────────────────

# Database ────────────────────────────────────────────────────────────────────
# Local dev uses a zero-config SQLite file. For production, point this at a
# managed Postgres (Neon / Supabase / RDS) and set DATABASE_PROVIDER=postgresql
# in prisma/schema.prisma. The data model is provider-portable.
DATABASE_URL="file:./dev.db"

# Auth ────────────────────────────────────────────────────────────────────────
# 32+ char secret used to sign session JWTs. A dev fallback is used if unset,
# but ALWAYS set a strong random value in production.
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# AI provider (generation) ────────────────────────────────────────────────────
# Pick ONE. Groq is free and fast (OpenAI-compatible Llama models) and takes
# precedence when set; Anthropic/Claude is the alternative. When neither is set,
# a fully-offline grounded mock model answers from retrieved chunks so the
# platform is demonstrable without any external dependency or cost.
#
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"   # or llama-3.1-8b-instant, gemma2-9b-it, openai/gpt-oss-20b

# App ─────────────────────────────────────────────────────────────────────────
# Public origin, used to build the embeddable widget snippet shown to admins.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
